# Production — salin ke .env.local di server (/var/www/rtgenz01/.env.local)
NODE_ENV=production

# Admin (wajib)
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
# Admin tambahan (opsional)
ADMIN_EMAIL_2=
ADMIN_PASSWORD_HASH_2=
# Generate hash: node -e "console.log(require('bcryptjs').hashSync('password-anda', 10))"
# Di .env.local: escape setiap $ menjadi \$ (contoh: \$2b\$10\$...)

# Password halaman /keuangan (wajib, berbeda dari admin)
KEUANGAN_PASSWORD_HASH=

# Media sosial (footer)
INSTAGRAM_URL=
YOUTUBE_URL=
