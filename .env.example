# Admin credentials (wajib)
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
# Generate hash: node -e "console.log(require('bcryptjs').hashSync('password-anda', 10))"
# Di .env.local: escape setiap $ menjadi \$ (contoh: \$2b\$10\$...)

# Password halaman /keuangan (wajib, berbeda dari admin)
KEUANGAN_PASSWORD_HASH=

# Media sosial (footer) — isi URL akun resmi RT
INSTAGRAM_URL=
YOUTUBE_URL=
